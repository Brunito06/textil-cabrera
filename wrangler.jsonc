{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "textil-cabrera",
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "textilcabrera.com.uy",
      "custom_domain": true
    }
  ]
}
